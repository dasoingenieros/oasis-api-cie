{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "documents/templates/**/*",
        "outDir": "dist"
      },
      {
        "include": "assets/**/*.xls",
        "outDir": "dist"
      },
      {
        "include": "assets/**/*.py",
        "outDir": "dist"
      },
      {
        "include": "assets/**/*.docx",
        "outDir": "dist"
      }
    ]
  }
}
