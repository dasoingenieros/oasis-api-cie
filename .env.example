# ── App ──
NODE_ENV=production
PORT=3001
API_PREFIX=api/v1

# ── Auth (cambiar según modo) ──
AUTH_MODE=embedded
# AUTH_MODE=external
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n..."
# AUTH_SERVICE_URL=http://oasis-auth:3010

# Para embedded:
JWT_SECRET=cambiar-en-produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambiar-refresh-secret-en-produccion
JWT_REFRESH_EXPIRES_IN=7d

# ── Database ──
DATABASE_URL=postgresql://cie:password@cie-postgres:5432/oasis_cie
CIE_DB_PASSWORD=password

# ── CORS ──
CORS_ORIGIN=http://localhost:3000

# ── Branding (white-label) ──
APP_NAME=CIE Platform
APP_DOMAIN=cie.oasisplatform.es
APP_URL=http://localhost:3000

# ── SMTP (Brevo) ──
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@oasisplatform.es
SMTP_FROM_NAME=CIE Platform

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
